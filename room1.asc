// room script file

function oKey_Interact(Object *theObject, CursorMode mode)
{
  player.AddInventory(iKey);
  oKey.Visible = false;
  Display("You picked up a rusty key.");
}

function hDoor_Look(Hotspot *theHotspot, CursorMode mode)
{
  player.Say("A nice wooden door.");
}

function hDoor_UseInv(Hotspot *theHotspot, CursorMode mode)
{
  if (player.ActiveInventory == iKey)
  {
    Display("It fits! The door unlocks.");
    player.LoseInventory(iKey);

    hDoor.Enabled = false;
    
    FadeOut(20);
    Wait(1);
    Display("End of demo. Thanks for playing!");
  }
  else
  {
    Display("That won't work.");
  }
}

function Room_enter()
{
  aSong.Play();
}
